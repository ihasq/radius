{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "types": ["bun"],
    "paths": {
      "@radius/radls-ts": ["./packages/radls-ts/src/index.ts"],
      "@radius/radls-ts/*": ["./packages/radls-ts/src/*"]
    }
  },
  "include": ["src/**/*.ts", "packages/**/*.ts"]
}
