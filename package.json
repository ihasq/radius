{
  "name": "radius",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "cli": "bun run src/cli/main.ts",
    "daemon": "bun run src/daemon/main.ts",
    "build": "./scripts/build.sh",
    "test": "bash scripts/test-parallel.sh",
    "test:serial": "bun test --timeout 60000",
    "test:dev": "bun test --bail --timeout 60000",
    "test:failures": "bun test --timeout 60000 2>&1 | awk '/^\\(fail\\)/,/^\\(pass\\)|^\\(fail\\)|^\\(skip\\)|^[0-9]+ pass/'"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/bun": "latest",
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.2.0",
    "vscode-textbuffer": "^1.0.0"
  }
}
